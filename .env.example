# ── Convex ────────────────────────────────────────────────────────────────────
# Get from Convex Dashboard → Settings → URL & Deploy Key
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# ── Clerk ─────────────────────────────────────────────────────────────────────
# Get from Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk auth domain for Convex (Clerk Dashboard → API Keys → Frontend API URL)
CLERK_FRONTEND_API_URL=https://your-clerk-domain.clerk.accounts.dev

# Clerk webhook secret (Clerk Dashboard → Webhooks → your webhook → Signing Secret)
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk auth routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/shop
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/shop

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from Stripe Dashboard → Developers → API Keys
# Also add STRIPE_SECRET_KEY to Convex environment variables (Dashboard → Settings → Env Vars)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe webhook secret — add to Convex env vars (not .env.local)
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
